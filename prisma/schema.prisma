generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                              String                      @id @default(uuid())
  email                           String                      @unique
  phone                           String?                     @unique
  password                        String
  firstName                       String
  lastName                        String
  avatar                          String?
  status                          UserStatus                  @default(PENDING)
  lastLoginAt                     DateTime?
  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt
  deletedAt                       DateTime?
  memberId                        String?                     @unique
  tenantId                        String?
  emailVerifiedAt                 DateTime?
  createdAnnouncements            Announcement[]
  attendances                     attendances[]
  auditLogs                       AuditLog[]                  @relation("AuditLogActor")
  createdCirculars                Circular[]
  comments                        Comment[]
  conversationParticipants        ConversationParticipant[]
  deviceTokens                    DeviceToken[]
  donations                       Donation[]                  @relation("DonationUser")
  emailVerificationTokens       EmailVerificationToken[]
  eventAttendees                  EventAttendee[]
  createdEvents                   Event[]
  groups                          groups[]
  invitationTokens               InvitationToken[]
  journeyInteractions             JourneyInteraction[]
  sentMessages                    Message[]                   @relation("MessageSender")
  mentoredVisitors                NewVisitor[]                @relation("VisitorMentor")
  newsPosts                      NewsPost[]
  notifications                   Notification[]
  passwordResetTokens             PasswordResetToken[]
  personalEvents                  PersonalEvent[]
  programs                        programs[]
  refreshTokens                   RefreshToken[]
  service_assignments             service_assignments[]
  service_plans                   service_plans[]
  shopOrders                      ShopOrder[]
  ownedTenants                    Tenant[] @relation("tenants_ownerIdTousers")
  uploads                         UploadAsset[]
  userReports                     UserReport[]  @relation("UserReports")
  resolvedReports                 UserReport[]  @relation("ResolvedReports")
  userRoles                       UserRole[]
  supervisedFamilies              FamilyOfDisciples[] @relation("FDSupervisor")
  soulAttendancesRecorded         SoulCulteAttendance[] @relation("AttendanceRecorder")
  journeyStepsCompleted           SoulJourneyStepProgress[] @relation("StepCompleter")
  recoveryCasesOpened             RecoveryCase[] @relation("CaseOpener")
  recoveryCasesAssigned           RecoveryCase[] @relation("CaseAssignee")
  createdCampaigns                PublicCampaign[] @relation("CampaignCreator")
  createdLiveChannels             LiveChannel[] @relation("LiveChannelCreator")
  createdLiveServices             LiveService[] @relation("LiveServiceCreator")
  liveHostAssignments             LiveHostAssignment[] @relation("LiveHostAssignments")
  liveChatMessages                LiveChatMessage[] @relation("LiveChatUser")
  liveViewerSessions              LiveViewerSession[] @relation("ViewerSessions")
  liveEngagements                 LiveEngagementEvent[] @relation("LiveEngagements")
  prayerRequestsAssigned          LivePrayerRequest[] @relation("PrayerAssignee")
  createdReplays                  MediaReplay[] @relation("ReplayCreator")
  recoveryCasesClosed             RecoveryCase[] @relation("CaseCloser")
  soulAssignmentsGiven            SoulAssignment[] @relation("AssignmentGiver")
  followUpTasksCreated            FollowUpTask[] @relation("TaskCreator")
  followUpTasksAssigned           FollowUpTask[] @relation("TaskAssignee")
  member                          Member?                     @relation(fields: [memberId], references: [id])
  tenant                          Tenant?                    @relation("users_tenantIdTotenants", fields: [tenantId], references: [id])

  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@index([tenantId])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  displayName     String
  description     String?
  level           Int
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
  @@index([level])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  displayName     String
  module          String
  action          String
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@index([module])
  @@index([name])
  @@map("permissions")
}

model UserRole {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  regionId   String?
  districtId String?
  assemblyId String?
  ministryId String?
  assignedAt DateTime  @default(now())
  assignedBy String?
  expiresAt  DateTime?
  tenantId   String?
  assembly   Assembly? @relation(fields: [assemblyId], references: [id])
  district   District? @relation(fields: [districtId], references: [id])
  ministry   Ministry? @relation(fields: [ministryId], references: [id])
  region     Region?   @relation(fields: [regionId], references: [id])
  role       Role      @relation(fields: [roleId], references: [id])
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([userId, roleId, tenantId, regionId, districtId, assemblyId, ministryId])
  @@index([userId])
  @@index([roleId])
  @@index([tenantId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  user      User      @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Region {
  id                String             @id @default(uuid())
  name              String
  code              String?
  description       String?
  latitude          Float?
  longitude         Float?
  status            String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  hqAssemblyId      String?
  tenantId          String
  announcements     Announcement[]
  assignments       Assignment[]
  circulars         Circular[]
  districts         District[]
  events            Event[]
  newsPosts        NewsPost[]
  hqAssembly        Assembly?          @relation("RegionHQ", fields: [hqAssemblyId], references: [id])
  tenant              Tenant                       @relation(fields: [tenantId], references: [id])
  territoryAccounts TerritoryAccount[]
  userRoles         UserRole[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([name])
  @@index([deletedAt])
  @@index([tenantId])
  @@map("regions")
}

model District {
  id                String             @id @default(uuid())
  name              String
  code              String?
  description       String?
  regionId          String
  latitude          Float?
  longitude         Float?
  status            String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  hqAssemblyId      String?
  announcements     Announcement[]
  assemblies        Assembly[]
  assignments       Assignment[]
  circulars         Circular[]
  hqAssembly        Assembly?          @relation("DistrictHQ", fields: [hqAssemblyId], references: [id])
  region            Region             @relation(fields: [regionId], references: [id])
  events            Event[]
  newsPosts        NewsPost[]
  territoryAccounts TerritoryAccount[]
  userRoles         UserRole[]

  @@unique([name, regionId])
  @@index([regionId])
  @@index([deletedAt])
  @@map("districts")
}

model Assembly {
  id                String             @id @default(uuid())
  name              String
  code              String?
  address           String?
  districtId        String
  latitude          Float?
  longitude         Float?
  status            String             @default("ACTIVE")
  phone             String?
  email             String?
  foundedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  announcements     Announcement[]
  district          District           @relation(fields: [districtId], references: [id])
  assignments       Assignment[]
  hqForDistricts    District[]         @relation("DistrictHQ")
  donations         Donation[]
  events            Event[]
  groups            groups[]
  members           Member[]
  ministries        Ministry[]
  newVisitors       NewVisitor[]
  newsPosts        NewsPost[]
  pastors           Pastor[]
  preachingPoints   PreachingPoint[]
  products          Product[]
  programs          programs[]
  hqForRegions      Region[]           @relation("RegionHQ")
  service_plans     service_plans[]
  shopOrders        ShopOrder[]
  territoryAccounts   TerritoryAccount[]
  transfersFrom       Transfer[]           @relation("TransferFromAssembly")
  transfersTo         Transfer[]           @relation("TransferToAssembly")
  userRoles           UserRole[]
  familiesOfDisciples FamilyOfDisciples[]
  liveChannels        LiveChannel[] @relation("AssemblyLiveChannels")
  liveServices        LiveService[] @relation("AssemblyLiveServices")
  mediaReplays        MediaReplay[] @relation("AssemblyReplays")

  @@unique([name, districtId])
  @@index([districtId])
  @@index([deletedAt])
  @@index([districtId, deletedAt])
  @@map("assemblies")
}

model PreachingPoint {
  id         String    @id @default(uuid())
  name       String
  address    String?
  assemblyId String
  latitude   Float?
  longitude  Float?
  status     String    @default("ACTIVE")
  leaderId   String?
  phone      String?
  foundedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  members    Member[]  @relation("PreachingPointMembers")
  assembly   Assembly  @relation(fields: [assemblyId], references: [id])

  @@index([assemblyId])
  @@index([deletedAt])
  @@map("preaching_points")
}

model Member {
  id               String           @id @default(uuid())
  matricule        String           @unique
  firstName        String
  lastName         String
  gender           Gender
  birthDate        DateTime?
  birthPlace       String?
  phone            String?
  email            String?
  address          String?
  photo            String?
  status           MemberStatus     @default(ACTIVE)
  assemblyId       String
  preachingPointId String?
  salvationDate    DateTime?
  baptismDate      DateTime?
  memberSince      DateTime?
  profession       String?
  maritalStatus    String?
  emergencyContact String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  isBaptized       Boolean          @default(false)
  isFirstTime      Boolean          @default(false)
  attendances      attendances[]
  donations        Donation[]
  eventAttendees   EventAttendee[]
  group_members    group_members[]
  assembly         Assembly         @relation(fields: [assemblyId], references: [id])
  preachingPoint   PreachingPoint?  @relation("PreachingPointMembers", fields: [preachingPointId], references: [id])
  ministryMembers  MinistryMember[]
  newcomerJourney  NewVisitor?      @relation("VisitorConvertedMember")
  invitedSouls     NewVisitor[]     @relation("SoulInvitedBy")
  ledFamilies      FamilyOfDisciples[] @relation("FDLeader")
  deputyFamilies   FamilyOfDisciples[] @relation("FDDeputy")
  discipleMakerProfile DiscipleMakerProfile?
  discipleMakerPartner DiscipleMakerProfile[] @relation("DMPartner")
  pastor           Pastor?
  transfers        Transfer[]       @relation("TransferMember")
  user             User?

  @@index([assemblyId])
  @@index([status])
  @@index([gender])
  @@index([matricule])
  @@index([deletedAt])
  @@index([assemblyId, status])
  @@index([assemblyId, deletedAt])
  @@index([lastName, firstName])
  @@map("members")
}

model Pastor {
  id          String          @id @default(uuid())
  memberId    String          @unique
  title       String?
  ordainedAt  DateTime?
  status      String          @default("ACTIVE")
  assemblyId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  assignments Assignment[]
  children    PastorChild[]
  diplomas    PastorDiploma[]
  spouse      PastorSpouse?
  assembly    Assembly?       @relation(fields: [assemblyId], references: [id])
  member      Member          @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([assemblyId])
  @@map("pastors")
}

model Assignment {
  id         String           @id @default(uuid())
  pastorId   String
  entityType String
  assemblyId String?
  districtId String?
  regionId   String?
  role       String?
  startDate  DateTime
  endDate    DateTime?
  status     AssignmentStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  assembly   Assembly?        @relation(fields: [assemblyId], references: [id])
  district   District?        @relation(fields: [districtId], references: [id])
  pastor     Pastor           @relation(fields: [pastorId], references: [id])
  region     Region?          @relation(fields: [regionId], references: [id])

  @@index([pastorId])
  @@index([status])
  @@index([entityType])
  @@map("assignments")
}

model Ministry {
  id                String           @id @default(uuid())
  name              String
  description       String?
  assemblyId        String
  leaderId          String?
  type              String?
  status            String           @default("ACTIVE")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  chatEnabled       Boolean          @default(false)
  memberListVisible Boolean          @default(true)
  joinMode          GroupJoinMode    @default(FREE)
  isPrivate         Boolean          @default(false)
  conversationId    String?          @unique
  announcements     Announcement[]
  assembly          Assembly         @relation(fields: [assemblyId], references: [id])
  conversation      Conversation?    @relation(fields: [conversationId], references: [id])
  members           MinistryMember[]
  newsPosts        NewsPost[]
  programs          programs[]
  userRoles         UserRole[]

  @@unique([name, assemblyId])
  @@index([assemblyId])
  @@index([deletedAt])
  @@map("ministries")
}

model MinistryMember {
  id         String    @id @default(uuid())
  ministryId String
  memberId   String
  role       String    @default("member")
  joinedAt   DateTime  @default(now())
  leftAt     DateTime?
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  member     Member    @relation(fields: [memberId], references: [id])
  ministry   Ministry  @relation(fields: [ministryId], references: [id])

  @@unique([ministryId, memberId])
  @@index([ministryId])
  @@index([memberId])
  @@map("ministry_members")
}

model Transfer {
  id              String         @id @default(uuid())
  memberId        String
  fromAssemblyId  String
  toAssemblyId    String
  requestedBy     String
  approvedBy      String?
  reason          String
  notes           String?
  status          TransferStatus @default(PENDING)
  requestedAt     DateTime       @default(now())
  processedAt     DateTime?
  effectiveDate   DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  fromAssembly    Assembly       @relation("TransferFromAssembly", fields: [fromAssemblyId], references: [id])
  member          Member         @relation("TransferMember", fields: [memberId], references: [id])
  toAssembly      Assembly       @relation("TransferToAssembly", fields: [toAssemblyId], references: [id])

  @@index([memberId])
  @@index([status])
  @@index([fromAssemblyId])
  @@index([toAssemblyId])
  @@map("transfers")
}

model Announcement {
  id          String             @id @default(uuid())
  title       String
  content     String
  level       AnnouncementLevel
  status      AnnouncementStatus @default(DRAFT)
  authorId    String
  regionId    String?
  districtId  String?
  assemblyId  String?
  ministryId  String?
  publishedAt DateTime?
  archivedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  scheduledAt DateTime?
  attachments Json               @default("[]")
  tenantId    String?
  assembly    Assembly?          @relation(fields: [assemblyId], references: [id])
  author      User               @relation(fields: [authorId], references: [id])
  district    District?          @relation(fields: [districtId], references: [id])
  ministry    Ministry?          @relation(fields: [ministryId], references: [id])
  region      Region?            @relation(fields: [regionId], references: [id])
  tenant     Tenant?           @relation(fields: [tenantId], references: [id])
  comments    Comment[]

  @@index([level])
  @@index([status])
  @@index([authorId])
  @@index([deletedAt])
  @@index([tenantId])
  @@map("announcements")
}

model Circular {
  id          String    @id @default(uuid())
  reference   String    @unique
  title       String
  content     String
  level       String
  status      String    @default("DRAFT")
  authorId    String
  regionId    String?
  districtId  String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  attachments Json      @default("[]")
  tenantId    String?
  author      User      @relation(fields: [authorId], references: [id])
  district    District? @relation(fields: [districtId], references: [id])
  region      Region?   @relation(fields: [regionId], references: [id])
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  comments    Comment[]

  @@index([status])
  @@index([level])
  @@index([deletedAt])
  @@index([tenantId])
  @@map("circulars")
}

model Event {
  id           String          @id @default(uuid())
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime?
  location     String?
  latitude     Float?
  longitude    Float?
  level        String
  status       EventStatus     @default(DRAFT)
  authorId     String
  regionId     String?
  districtId   String?
  assemblyId   String?
  maxAttendees Int?
  isPublic     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  tenantId     String?
  comments     Comment[]
  attendees    EventAttendee[]
  soulArrivals NewVisitor[]    @relation("SoulArrivalEvent")
  soulAttendances SoulCulteAttendance[]
  liveServices LiveService[]   @relation("EventLiveService")
  assembly     Assembly?       @relation(fields: [assemblyId], references: [id])
  author       User            @relation(fields: [authorId], references: [id])
  district     District?       @relation(fields: [districtId], references: [id])
  region       Region?         @relation(fields: [regionId], references: [id])
  tenant      Tenant?        @relation(fields: [tenantId], references: [id])

  @@index([startDate])
  @@index([status])
  @@index([level])
  @@index([deletedAt])
  @@index([tenantId])
  @@map("events")
}

model Notification {
  id         String             @id @default(uuid())
  userId     String
  title      String
  message    String
  type       NotificationType   @default(INFO)
  status     NotificationStatus @default(UNREAD)
  entityType String?
  entityId   String?
  data       Json?
  readAt     DateTime?
  createdAt  DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  action     AuditAction
  entityType String?
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())
  tenantId   String?
  actor      User?       @relation("AuditLogActor", fields: [actorId], references: [id])
  tenant    Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([tenantId])
  @@map("audit_logs")
}

model Comment {
  id             String            @id @default(uuid())
  content        String
  targetType     CommentTargetType
  authorId       String
  announcementId String?
  circularId     String?
  eventId        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  newsPostId     String?
  parentId       String?
  announcement   Announcement?     @relation(fields: [announcementId], references: [id])
  author         User              @relation(fields: [authorId], references: [id])
  circular       Circular?         @relation(fields: [circularId], references: [id])
  event          Event?            @relation(fields: [eventId], references: [id])
  newsPosts     NewsPost?       @relation(fields: [newsPostId], references: [id])
  comments       Comment?          @relation("commentsTocomments", fields: [parentId], references: [id])
  other_comments Comment[]         @relation("commentsTocomments")

  @@index([authorId])
  @@index([announcementId])
  @@index([circularId])
  @@index([eventId])
  @@index([targetType, createdAt])
  @@index([deletedAt])
  @@index([newsPostId])
  @@index([parentId])
  @@map("comments")
}

model PersonalEvent {
  id          String              @id @default(uuid())
  userId      String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  notes       String?
  color       String?
  isAllDay    Boolean             @default(false)
  status      PersonalEventStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  user        User                @relation(fields: [userId], references: [id])

  @@index([userId, startDate])
  @@index([deletedAt])
  @@map("personal_events")
}

model Donation {
  id                String         @id @default(uuid())
  reference         String         @unique
  userId            String?
  memberId          String?
  assemblyId        String?
  amount            Decimal        @db.Decimal(12, 2)
  currency          String         @default("XAF")
  method            DonationMethod
  status            DonationStatus @default(PENDING)
  purpose           String?
  notes             String?
  provider          String?
  providerReference String?
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  assembly          Assembly?      @relation(fields: [assemblyId], references: [id])
  member            Member?        @relation(fields: [memberId], references: [id])
  user              User?          @relation("DonationUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([memberId])
  @@index([assemblyId])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("donations")
}

model DeviceToken {
  id         String         @id @default(uuid())
  userId     String
  token      String         @unique
  platform   DevicePlatform
  provider   String         @default("expo")
  appVersion String?
  deviceName String?
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  revokedAt  DateTime?
  user       User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([platform])
  @@index([revokedAt])
  @@map("device_tokens")
}

model UploadAsset {
  id           String          @id @default(uuid())
  uploadedById String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  kind         UploadAssetKind
  url          String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  uploadedBy   User            @relation(fields: [uploadedById], references: [id])

  @@index([uploadedById, createdAt])
  @@index([kind])
  @@index([deletedAt])
  @@map("upload_assets")
}

model Conversation {
  id           String                    @id @default(uuid())
  title        String?
  isGroup      Boolean                   @default(false)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  deletedAt    DateTime?
  participants ConversationParticipant[]
  messages     Message[]
  ministry     Ministry?

  @@index([createdAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  role           String       @default("member")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           String       @default("text")
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
