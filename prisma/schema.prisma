}

model PublicLink {
  id         String     @id @default(uuid())
  campaignId String
  slug       String     @unique
  source     LinkSource @default(DEFAULT)
  label      String?
  isActive   Boolean    @default(true)
  expiresAt  DateTime?
  scans      Int        @default(0)
  createdAt  DateTime   @default(now())

  campaign    PublicCampaign     @relation(fields: [campaignId], references: [id])
