  processedAt    DateTime?

  campaign   PublicCampaign           @relation(fields: [campaignId], references: [id])
  publicLink PublicLink?              @relation(fields: [publicLinkId], references: [id])
  actions    PublicSubmissionAction[]

  @@index([tenantId, campaignId])
  @@index([tenantId, status])
  @@index([submittedAt])
  @@map("public_submissions")
}

model PublicSubmissionAction {
  id               String                 @id @default(uuid())
  submissionId     String
  actionType       SubmissionActionType
  targetEntityType String?
  targetEntityId   String?
  status           SubmissionActionStatus @default(PENDING)
  errorMessage     String?
  createdAt        DateTime               @default(now())

  submission PublicSubmission @relation(fields: [submissionId], references: [id])

  @@index([submissionId])
  @@map("public_submission_actions")
}

model PublicCampaignMetric {
  id                String   @id @default(uuid())
  campaignId        String
  date              DateTime @db.Date
  views             Int      @default(0)
  scans             Int      @default(0)
