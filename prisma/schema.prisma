model LiveChannel {
  id           String           @id @default(uuid())
  tenantId     String
  assemblyId   String?
  name         String
  provider     LiveProvider
  streamUrl    String?
  externalId   String?
  embedCode    String?
  isDefault    Boolean          @default(false)
  isActive     Boolean          @default(true)
  settings     Json             @default("{}")
  createdById  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant     Tenant        @relation("TenantLiveChannels", fields: [tenantId], references: [id])
  assembly   Assembly?     @relation("AssemblyLiveChannels", fields: [assemblyId], references: [id])
  createdBy  User          @relation("LiveChannelCreator", fields: [createdById], references: [id])
  services   LiveService[]

  @@index([tenantId, isActive])
  @@index([assemblyId])
  @@map("live_channels")
}

model LiveService {
  id                    String            @id @default(uuid())
  tenantId              String
  assemblyId            String
  channelId             String?
  eventId               String?
  title                 String
  description           String?
  type                  LiveServiceType   @default(SUNDAY_SERVICE)
  status                LiveServiceStatus @default(DRAFT)
  visibility            LiveVisibility    @default(PUBLIC)
  slug                  String            @unique
  thumbnailUrl          String?
  provider              LiveProvider?
  externalLiveId        String?
  embedUrl              String?
  scheduledStartAt      DateTime?
  scheduledEndAt        DateTime?
  actualStartAt         DateTime?
  actualEndAt           DateTime?
  allowChat             Boolean           @default(true)
  allowPrayer           Boolean           @default(true)
  allowDonations        Boolean           @default(true)
  allowVisitorSignup    Boolean           @default(true)
  allowSalvationDecision Boolean          @default(true)
  viewCount             Int               @default(0)
  peakViewerCount       Int               @default(0)
  language              String?
  tags                  String[]
  createdById           String
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?

  tenant        Tenant              @relation("TenantLiveServices", fields: [tenantId], references: [id])
  assembly      Assembly            @relation("AssemblyLiveServices", fields: [assemblyId], references: [id])
  channel       LiveChannel?        @relation(fields: [channelId], references: [id])
  event         Event?              @relation("EventLiveService", fields: [eventId], references: [id])
  createdBy     User                @relation("LiveServiceCreator", fields: [createdById], references: [id])
  chatMessages  LiveChatMessage[]
  prayerRequests LivePrayerRequest[]
  viewerSessions LiveViewerSession[]
  moments       LiveMoment[]
  engagements   LiveEngagementEvent[]
  replays       MediaReplay[]
  hosts         LiveHostAssignment[]

