  @@index([campaignId])
  @@index([slug])
  @@map("public_links")
}

model QrCodeAsset {
  id            String   @id @default(uuid())
  publicLinkId  String
  format        QrFormat @default(PNG)
  fileUrl       String
  label         String?
  designOptions Json     @default("{}")
  createdAt     DateTime @default(now())

  publicLink PublicLink @relation(fields: [publicLinkId], references: [id])

  @@index([publicLinkId])
  @@map("qr_code_assets")
}

model PublicSubmission {
  id             String           @id @default(uuid())
  tenantId       String
  campaignId     String
  publicLinkId   String?
  submittedAt    DateTime         @default(now())
  ipHash         String?
  userAgent      String?
  sourceMetadata Json             @default("{}")
