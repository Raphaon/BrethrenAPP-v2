// ─── Consolidation Module Models ──────────────────────────────────────────────

model FamilyOfDisciples {
  id            String      @id @default(uuid())
  tenantId      String
  assemblyId    String
  name          String
  description   String?
  status        FDStatus    @default(ACTIVE)
  leaderId      String
  deputyLeaderId String?
  supervisorId  String?
  goal          Int         @default(10)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  assembly   Assembly        @relation(fields: [assemblyId], references: [id])
  leader     Member          @relation("FDLeader", fields: [leaderId], references: [id])
  deputy     Member?         @relation("FDDeputy", fields: [deputyLeaderId], references: [id])
  supervisor User?           @relation("FDSupervisor", fields: [supervisorId], references: [id])
  souls       NewVisitor[]         @relation("FDSouls")
  makers      DiscipleMakerProfile[]
  assignments SoulAssignment[]

  @@unique([name, assemblyId])
  @@index([tenantId])
  @@index([assemblyId])
  @@index([status])
  @@index([deletedAt])
  @@map("families_of_disciples")
}

model DiscipleMakerProfile {
  id        String    @id @default(uuid())
  tenantId  String
  memberId  String    @unique
  familyId  String?
  partnerId String?
  maxLoad   Int       @default(10)
  isActive  Boolean   @default(true)
  startedAt DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  member          Member              @relation(fields: [memberId], references: [id])
  family          FamilyOfDisciples?  @relation(fields: [familyId], references: [id])
  partner         Member?             @relation("DMPartner", fields: [partnerId], references: [id])
  primarySouls    NewVisitor[]        @relation("PrimaryMakerSouls")
  secondarySouls  NewVisitor[]        @relation("SecondaryMakerSouls")
  assignments     SoulAssignment[]

  @@index([tenantId])
  @@index([familyId])
  @@index([isActive])
  @@map("disciple_maker_profiles")
}

model SoulAssignment {
  id               String    @id @default(uuid())
  soulId           String
  discipleMakerId  String
  assignedById     String
  familyId         String?
  assignedAt       DateTime  @default(now())
  endedAt          DateTime?
  reason           String?
  isPrimary        Boolean   @default(true)

  soul          NewVisitor           @relation(fields: [soulId], references: [id])
  discipleMaker DiscipleMakerProfile @relation(fields: [discipleMakerId], references: [id])
  assignedBy    User                 @relation("AssignmentGiver", fields: [assignedById], references: [id])
  family        FamilyOfDisciples?   @relation(fields: [familyId], references: [id])

  @@index([soulId])
  @@index([discipleMakerId])
  @@index([familyId])
  @@map("soul_assignments")
}

model SoulCulteAttendance {
  id              String                @id @default(uuid())
  soulId          String
  culteDate       DateTime              @db.Date
  eventId         String?
  status          SoulAttendanceStatus  @default(PRESENT)
  absenceReason   AbsenceReason?
  promisedToCome  Boolean               @default(false)
  wakeUpCallDone  Boolean               @default(false)
  transportNeeded Boolean               @default(false)
  transportOffered Boolean              @default(false)
  notes           String?
  recordedById    String
  createdAt       DateTime              @default(now())

  soul       NewVisitor  @relation(fields: [soulId], references: [id])
  event      Event?      @relation(fields: [eventId], references: [id])
  recordedBy User        @relation("AttendanceRecorder", fields: [recordedById], references: [id])

  @@unique([soulId, culteDate])
  @@index([soulId])
  @@index([culteDate])
  @@index([eventId])
  @@map("soul_culte_attendances")
}

model ConsolidationJourneyTemplate {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  durationDays Int       @default(30)
  isDefault    Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant   Tenant                    @relation(fields: [tenantId], references: [id])
  steps    ConsolidationStepTemplate[]
  journeys SoulConsolidationJourney[]

  @@index([tenantId])
  @@map("consolidation_journey_templates")
}

model ConsolidationStepTemplate {
  id           String           @id @default(uuid())
  templateId   String
  title        String
  description  String?
  dueAfterDays Int
  order        Int
  isRequired   Boolean          @default(true)
  stepType     JourneyStepType  @default(OTHER)

  template  ConsolidationJourneyTemplate @relation(fields: [templateId], references: [id])
  progress  SoulJourneyStepProgress[]

  @@index([templateId])
  @@map("consolidation_step_templates")
}

model SoulConsolidationJourney {
  id          String                @id @default(uuid())
  soulId      String
  templateId  String
  status      JourneyInstanceStatus @default(IN_PROGRESS)
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  notes       String?

  soul     NewVisitor                   @relation(fields: [soulId], references: [id])
  template ConsolidationJourneyTemplate @relation(fields: [templateId], references: [id])
  steps    SoulJourneyStepProgress[]

  @@unique([soulId, templateId])
  @@index([soulId])
  @@index([status])
  @@map("soul_consolidation_journeys")
}

model SoulJourneyStepProgress {
  id               String      @id @default(uuid())
  journeyId        String
  stepTemplateId   String
  status           StepStatus  @default(PENDING)
  completedAt      DateTime?
  completedById    String?
  notes            String?

  journey      SoulConsolidationJourney  @relation(fields: [journeyId], references: [id])
  stepTemplate ConsolidationStepTemplate @relation(fields: [stepTemplateId], references: [id])
  completedBy  User?                     @relation("StepCompleter", fields: [completedById], references: [id])

  @@unique([journeyId, stepTemplateId])
  @@map("soul_journey_step_progress")
}

model RecoveryCase {
  id           String              @id @default(uuid())
  soulId       String
  tenantId     String
  reason       String
  openedAt     DateTime            @default(now())
  openedById   String
  assignedToId String?
  status       RecoveryCaseStatus  @default(OPEN)
  decision     RecoveryDecision?
  closedAt     DateTime?
  closedById   String?
  notes        String?

  soul       NewVisitor  @relation(fields: [soulId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  openedBy   User        @relation("CaseOpener", fields: [openedById], references: [id])
  assignedTo User?       @relation("CaseAssignee", fields: [assignedToId], references: [id])
  closedBy   User?       @relation("CaseCloser", fields: [closedById], references: [id])

  @@index([tenantId])
  @@index([soulId])
  @@index([status])
  @@map("recovery_cases")
}

model FollowUpTask {
  id           String      @id @default(uuid())
  tenantId     String
  soulId       String
  assignedToId String
  type         TaskType    @default(CALL)
  dueAt        DateTime
  status       TaskStatus  @default(PENDING)
  completedAt  DateTime?
  notes        String?
  createdById  String
  createdAt    DateTime    @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  soul       NewVisitor  @relation(fields: [soulId], references: [id])
  assignedTo User        @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy  User        @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([soulId])
  @@index([assignedToId])
  @@index([dueAt])
  @@index([status])
  @@map("follow_up_tasks")
}

// ─── Portail public / QR Codes / Campagnes ──────────────────────────────────

model PublicCampaign {
  id          String            @id @default(uuid())
  tenantId    String
  title       String
  description String?
  type        CampaignType
  status      CampaignStatus    @default(DRAFT)
  scopeType   CampaignScopeType @default(ASSEMBLY)
  scopeId     String?
  settings    Json              @default("{}")
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  tenant      Tenant                @relation("TenantCampaigns", fields: [tenantId], references: [id])
  createdBy   User                  @relation("CampaignCreator", fields: [createdById], references: [id])
  links       PublicLink[]
  submissions PublicSubmission[]
  metrics     PublicCampaignMetric[]
  liveMoments LiveMoment[]           @relation("MomentCampaign")

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([deletedAt])
