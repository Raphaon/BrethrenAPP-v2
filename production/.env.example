POSTGRES_USER=brethren_user
POSTGRES_PASSWORD=change_me_with_a_strong_database_password
POSTGRES_DB=brethren_db

API_PORT=3000
API_VERSION=v1
APP_NAME=Brethren API
BASE_URL=https://api.tondomaine.com
FRONTEND_URL=https://admin.tondomaine.com
CORS_ORIGIN=https://admin.tondomaine.com
CORS_CREDENTIALS=true

JWT_ACCESS_SECRET=generate_with_node_crypto_randomBytes_64_hex
JWT_REFRESH_SECRET=generate_another_node_crypto_randomBytes_64_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_DAYS=7

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
LOG_LEVEL=info

SMTP_HOST=smtp.tonservice.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@tondomaine.com
SMTP_PASS=change_me
SMTP_FROM="MPE Cameroun" <noreply@tondomaine.com>

# Optional. Prefer S3/R2/Spaces in production for durable uploads.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
