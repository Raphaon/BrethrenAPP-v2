# ─── Application ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1
APP_NAME=BrethrenApp API
BASE_URL=https://api-demo.brethrenapp.com

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/brethren_db

# ─── JWT — générer avec : openssl rand -hex 64 ────────────────────────
JWT_ACCESS_SECRET=change_this_to_a_random_64_char_string_min
JWT_REFRESH_SECRET=change_this_to_a_different_random_64_char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_DAYS=7

# ─── CORS — ne pas inclure localhost en production ─────────────────────
CORS_ORIGIN=https://demo-app.brethrenapp.com
CORS_CREDENTIALS=true

# ─── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# ─── Pagination ────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Email SMTP ────────────────────────────────────────────────────────
# Requis en production pour que le reset de mot de passe fonctionne.
# Compatible avec n'importe quel fournisseur SMTP :
#   Resend   → host=smtp.resend.com  port=465  secure=true  user=resend
#   SendGrid → host=smtp.sendgrid.net port=587  secure=false user=apikey
#   Gmail    → host=smtp.gmail.com   port=587  secure=false user=votre@gmail.com
#   OVH      -> host=ssl0.ovh.net     port=465  secure=true  user=votre@domaine.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
SMTP_FROM="BrethrenApp" <noreply@brethrenapp.com>
FRONTEND_URL=https://demo-app.brethrenapp.com

# ─── Stockage Fichiers S3 ──────────────────────────────────────────────
# Optionnel - si non defini, les fichiers sont stockes localement (public/uploads/).
# Pour un vrai environnement de production, preferer S3/R2/Spaces afin de garder
# les fichiers meme apres deplacement du conteneur ou restauration serveur.
# Compatible AWS S3, DigitalOcean Spaces, Cloudflare R2, MinIO.
#   AWS S3              -> S3_REGION=eu-west-1 (pas de S3_ENDPOINT)
#   DigitalOcean Spaces -> S3_ENDPOINT=https://fra1.digitaloceanspaces.com
#   Cloudflare R2       -> S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   MinIO (self-hosted) -> S3_ENDPOINT=http://minio:9000
S3_BUCKET=brethren-uploads
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# S3_ENDPOINT=https://fra1.digitaloceanspaces.com
